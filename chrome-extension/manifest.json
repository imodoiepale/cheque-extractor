{
  "manifest_version": 3,
  "name": "CheckSync Pro",
  "version": "1.0.0",
  "description": "AI-powered check reconciliation for QuickBooks. Upload checks, auto-match, and mark transactions as Cleared — right from your browser.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "CheckSync Pro"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.intuit.com/*",
        "https://app.qbo.intuit.com/*",
        "https://qbo.intuit.com/*",
        "https://c*.qbo.intuit.com/*"
      ],
      "js": ["content/qbo-overlay.js"],
      "css": ["content/qbo-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "identity",
    "activeTab",
    "notifications"
  ],
  "host_permissions": [
    "https://*.supabase.co/*",
    "https://quickbooks.api.intuit.com/*",
    "https://oauth.platform.intuit.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "popup/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options/options.html"
}
