# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env or .env.local for development
# For production (Railway, Render, etc.), set these in the dashboard

# ── Supabase Database ────────────────────────
# REQUIRED: Get these from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yqbmzerdagqevjdwhlwh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlxYm16ZXJkYWdxZXZqZHdobHdoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTczMjUzNjk3NywiZXhwIjoyMDQ4MTEyOTc3fQ.YOUR_SERVICE_ROLE_KEY_HERE

# Alternative name (backend uses both)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlxYm16ZXJkYWdxZXZqZHdobHdoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTczMjUzNjk3NywiZXhwIjoyMDQ4MTEyOTc3fQ.YOUR_SERVICE_ROLE_KEY_HERE

# ── AI/OCR API Keys ──────────────────────────
# REQUIRED: Gemini API for AI-powered extraction
# Get from https://aistudio.google.com/app/apikey
# Can provide multiple keys separated by commas for rotation
GEMINI_API_KEYS=AIzaSyABC123_YOUR_FIRST_KEY,AIzaSyDEF456_YOUR_SECOND_KEY
# Or single key:
GEMINI_API_KEY=AIzaSyABC123_YOUR_GEMINI_KEY

# OPTIONAL: OpenAI as backup for Gemini failures
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-ABC123_YOUR_OPENAI_KEY_HERE

# ── Authentication (Optional) ────────────────
# Set to "true" to require JWT authentication on API calls
# Leave empty or "false" for development without auth
REQUIRE_AUTH=false

# JWT secret for token verification (if REQUIRE_AUTH=true)
JWT_SECRET=your_jwt_secret_key_here

# ── Server Configuration ─────────────────────
# Port for the backend server (default: 3090)
PORT=3090

# ── Tesseract OCR ────────────────────────────
# Windows: Usually auto-detected at C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Docker: Install via apt-get install tesseract-ocr
# No env variable needed if installed in standard location
