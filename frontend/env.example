# ── QuickBooks OAuth ─────────────────────────
# OPTIONAL: Only needed if using QuickBooks integration
# Get from https://developer.intuit.com → Your App → Keys & Credentials
QUICKBOOKS_CLIENT_ID=your_intuit_client_id
QUICKBOOKS_CLIENT_SECRET=your_intuit_client_secret
QUICKBOOKS_REDIRECT_URI=https://check-extractor-frontend.vercel.app/api/qbo/callback

# Alternative: Store in Supabase integrations table instead
# Then you can configure via Settings → Integrations in the app

# ── Application URL ──────────────────────────
# OPTIONAL: Used for OAuth redirects if not set explicitly
NEXT_PUBLIC_APP_URL=https://check-extractor-frontend.vercel.app
